{
    "C_Cpp.autocomplete": "default",
    "C_Cpp.errorSquiggles": "enabled",
    "C_Cpp.intelliSenseEngine": "default",
    "clangd.arguments": [
        "-header-insertion=never",
        "-log=verbose",
        "-pretty",
        "--background-index",
        "--compile-commands-dir=${workspaceFolder}/build.aarch64/build/Debug",
        "--clang-tidy",
        "--completion-style=detailed",
        "--fallback-style=google",
    ],
    "editor.formatOnSave": true,
    "files.associations": {
        "memory": "cpp",
        "qapplication": "cpp",
        "qcoreapplication": "cpp",
        "qdatetime": "cpp",
        "qnetworkaddressentry": "cpp",
        "qwidget": "cpp",
